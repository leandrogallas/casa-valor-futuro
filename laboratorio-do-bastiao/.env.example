# Copie para .env e preencha os valores antes de subir com docker compose.
# Nunca commite o arquivo .env real.

# ── Server ──────────────────────────────────────────────────────────────────
# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=TROQUE_ISSO_ANTES_DE_IR_PARA_PRODUCAO

# Porta em que o servidor escuta (REST + WebSocket Colyseus)
PORT=2567

# ── Client ───────────────────────────────────────────────────────────────────
# Porta HTTP do nginx servindo o cliente
CLIENT_PORT=80

# URL WebSocket do servidor — embutida no bundle Vite em build time.
# Local:  ws://localhost:2567
# VPS:    ws://<IP_OU_DOMINIO>:2567   ou   wss://<DOMINIO> (com TLS)
VITE_SERVER_URL=ws://localhost:2567

# ── Agents (necessário somente com --profile agents) ─────────────────────────
# UUID do agente criado via POST /agentes
AGENT_ID=

# URL HTTP do servidor (dentro da rede Docker: http://server:2567)
SERVER_URL=http://server:2567

# Chave da API Anthropic — obtenha em https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-
